      "title": "Karma Score — All Flows",
      "type": "timeseries",
      "datasource": { "type": "influxdb", "uid": "InfluxDB" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "flow_1" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ff1744", "mode": "fixed" } }, { "id": "displayName", "value": "CUBIC" }] },
          { "matcher": { "id": "byName", "options": "flow_2" }, "properties": [{ "id": "color", "value": { "fixedColor": "#00e5ff", "mode": "fixed" } }, { "id": "displayName", "value": "BBR" }] },
